# ─────────────────────────────────────────────────────────────────────────────
# Travel Planning Agent — environment configuration
# Copy this file to .env and fill in the values you need.
# Only the provider you actually use requires an API key.
# ─────────────────────────────────────────────────────────────────────────────

# ── Active LLM provider & model ───────────────────────────────────────────────
# Supported: ollama | anthropic | openai | groq | together | gemini
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:8b

# ── Ollama (local, no key needed) ─────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ── Together AI ───────────────────────────────────────────────────────────────
TOGETHER_API_KEY=

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com → Get API key
# Models: gemini-2.5-flash | gemini-2.5-pro | gemini-2.0-flash | gemini-2.0-flash-lite
GEMINI_API_KEY=

# ── Tool provider modes ───────────────────────────────────────────────────────
# "mock" uses dummy_data/ (offline, no key needed)
# "api"  calls external services (requires the matching API key below)

WEATHER_MODE=mock
# WEATHER_API_KEY=          # not required — Open-Meteo is free

ACTIVITIES_MODE=mock
# TICKETMASTER_API_KEY=     # required when ACTIVITIES_MODE=api

ONLINE_DESTINATIONS_MODE=mock
# TRAVEL_API_KEY=           # required when ONLINE_DESTINATIONS_MODE=api
