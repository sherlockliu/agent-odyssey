# LLM Provider Configuration
# Supported providers: anthropic, ollama, gemini
LLM_PROVIDER=anthropic

# Anthropic: claude-haiku-3-5-20241022, claude-sonnet-4-5, claude-opus-4
# Gemini: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash
# Ollama: qwen3:8b, llama3.2, etc.
LLM_MODEL=claude-haiku-3-5-20241022

# Required for anthropic provider
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required for gemini provider
GEMINI_API_KEY=your-gemini-api-key-here

# Ollama host (if using ollama provider)
OLLAMA_HOST=http://localhost:11434

# Tool data modes: mock (no API keys needed) or api
WEATHER_MODE=mock
ACTIVITIES_MODE=mock
