{
  "name": "travel-agent",
  "version": "1.0.0",
  "description": "Claude Code-style travel planning agent built with TypeScript + React + Ink",
  "type": "module",
  "scripts": {
    "dev": "node --no-warnings --loader ts-node/esm src/index.tsx",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^16.0.0",
    "ink": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
